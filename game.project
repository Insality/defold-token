[bootstrap]
main_collection = /example/example.collectionc

[script]
shared_state = 1

[display]
width = 960
height = 640

[android]
input_method = HiddenInputField

[project]
title = Defold Token
version = 4
publisher = Insality
developer = Maksim Tuprikov, Insality
custom_resources = /resources,/test/resources
dependencies#0 = https://github.com/britzl/deftest/archive/refs/tags/2.8.0.zip
dependencies#1 = https://github.com/Insality/defold-event/archive/refs/tags/14.zip
dependencies#2 = https://github.com/Insality/druid/archive/refs/tags/1.2.0.zip
dependencies#3 = https://github.com/Insality/asset-store/archive/refs/tags/2.zip
dependencies#4 = https://github.com/Insality/defold-saver/archive/refs/tags/6.zip

[library]
include_dirs = token

[log]
level = ERROR
level_release = WARN
time_tracking = 1
memory_tracking = 1
info_block_length = 18
info_block = %levelshort[%logger
message_block = ]: %message %context %tab<%function>

[input]
game_binding = /builtins/input/all.input_bindingc

